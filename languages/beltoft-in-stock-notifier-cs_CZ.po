#: src/Email/BackInStockEmail.php:43
msgid "Back In Stock"
msgstr "Produkt opět naskladněn"

#: src/Email/BackInStockEmail.php:44
msgid ""
"Sent to customers who subscribed for a back-in-stock notification when the "
"product returns to stock."
msgstr ""
"Zasláno zákazníkům, kteří se přihlásili k odběru oznámení o dostupnosti "
"produktu."

#: src/Email/BackInStockEmail.php:64
msgid "{product_name} is back in stock!"
msgstr "{product_name} je opět na skladě!"

#: src/Email/BackInStockEmail.php:73
msgid "It's back in stock!"
msgstr "Produkt opět naskladněn!"

#. translators: 1: product name, 2: site name
#: src/Email/BackInStockEmail.php:83
msgid "Good news! {product_name} is back in stock at {site_title}."
msgstr ""
"Dobrá zpráva! Produkt {product_name} je opět na skladě na {site_title}."

#: src/Email/BackInStockEmail.php:92
msgid "Shop Now"
msgstr "Jít nakupovat"

#. translators: 1: site name
#: src/Email/BackInStockEmail.php:102
msgid ""
"You received this email because you subscribed to a back-in-stock "
"notification on {site_title}."
msgstr ""
"Tento e-mail jste obdrželi, protože jste se zaregistrovali k hlídání "
"dostupnosti produktu na {site_title}."

#: src/Email/BackInStockEmail.php:274
msgid "Sample Product"
msgstr "Ukázkový produkt"

