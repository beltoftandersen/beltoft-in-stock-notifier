#. Plugin Name of the plugin
#: beltoft-in-stock-notifier.php
msgid "Beltoft In-Stock Notifier for WooCommerce"
msgstr ""

#. Plugin URI of the plugin
#: beltoft-in-stock-notifier.php
msgid "https://wordpress.org/plugins/beltoft-in-stock-notifier/"
msgstr ""

#. Description of the plugin
#: beltoft-in-stock-notifier.php
msgid ""
"Let customers subscribe to out-of-stock product notifications and "
"automatically email them when items are back in stock."
msgstr ""
"Permita que os clientes subscrevam notificações de produtos esgotados e "
"envie-lhes automaticamente um email quando os artigos voltarem ao stock."

#. Author of the plugin
#: beltoft-in-stock-notifier.php
msgid "beltoft.net"
msgstr ""

#. Author URI of the plugin
#: beltoft-in-stock-notifier.php
msgid "https://beltoft.net"
msgstr ""

#. translators: %s: WooCommerce plugin name
#: beltoft-in-stock-notifier.php:55
msgid "In-Stock Notifier requires WooCommerce to be installed and active."
msgstr ""
"O Notificador de Stock requer que o WooCommerce esteja instalado e ativo."

